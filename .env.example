# NexusQueue local dev configuration
# Copy to .env and adjust as needed.

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Postgres ---
# matches docker-compose default
DATABASE_URL=postgres://nexus:nexus@localhost:5432/nexusqueue

# --- Server (Producer + REST API) ---
SERVER_PORT=3000
SERVER_HOST=0.0.0.0

# --- Worker ---
WORKER_QUEUE=default
WORKER_CONCURRENCY=1
WORKER_ID=worker-local-1

# --- Auth ---
# Comma-separated list of valid API keys for job submission (POST /jobs).
# Leave empty to disable API key auth.
API_KEYS=

# Secret used to sign and verify JWT tokens for dashboard routes.
# Leave empty to disable JWT auth.
JWT_SECRET=

# Credentials for POST /auth/login to obtain a JWT.
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# --- Logging ---
LOG_LEVEL=info
NODE_ENV=development
