# NexusQueue local dev configuration
# Copy to .env and adjust as needed.

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Postgres ---
# matches docker-compose default
DATABASE_URL=postgres://nexus:nexus@localhost:5432/nexusqueue

# --- Server (Producer + REST API) ---
SERVER_PORT=3000
SERVER_HOST=0.0.0.0

# --- Worker ---
WORKER_QUEUE=default
WORKER_CONCURRENCY=1
WORKER_ID=worker-local-1
